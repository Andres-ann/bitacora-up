<!doctype html>
<html lang="es">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://i.ibb.co/ZNyjQ2g/favicon.jpg">

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">

    <title>Bitacora UP | Editar </title>
</head>

<body>
    <% if (item) { %>
    <div class="container">
        <div class="card mt-5 p-lg-5 mx-auto shadow">
            <div class="card-title m-4">
                <h3 class="display-3">Editar frase</h3>
            </div>
            <div class="p-4">
                <form action="/update" method="POST">
                    <input id="id" name="id" value="<%= item.id %>" hidden>
                    <div class="mb-3">
                        <label for="frase" lass="form-label">Frase</label>
                        <input class="form-control mt-2" placeholder="Ingresa una nueva frase" value="<%= item.frase %>"
                            name="frase" id="frase"> </input>
                        <div class="mb-3">
                            <label for="autor" class="form-label mt-2">Autor</label>
                            <input type="text" class="form-control" placeholder="¿Quién lo dijo?"
                                value="<%= item.autor %>" name="autor" id="autor">
                        </div>
                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-success me-1">
                                <i class="bi bi-check2-circle"></i> Guardar
                            </button>
                            <a href="/" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancelar
                            </a>
                        </div>
                </form>
            </div>

        </div>

    </div>
    <% } %>



    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous">
    </script>
</body>

</html>