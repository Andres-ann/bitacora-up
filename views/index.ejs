    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Alert Delete -->
    <script>
        function confirm(id) {
            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger'
                },
                buttonsStyling: false
            })

            swalWithBootstrapButtons.fire({
                title: '¿Estás seguro que deseas eliminar esta frase?',
                text: "Esta acción no tiene vuelta atrás!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Si, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        icon: 'question',
                        title: 'Ingresa la contraseña para eliminar',
                        html: `<input type="password" id="password" class="swal2-input" placeholder="Contraseña...">`,
                        confirmButtonText: 'OK',
                        preConfirm: () => {
                            const password = Swal.getPopup().querySelector('#password').value
                            if (password === '') {
                                Swal.showValidationMessage(`Por favor, ingresa una contraseña`)
                            } else if (password === '!delete') {
                                Swal.fire({
                                    position: 'center',
                                    icon: 'success',
                                    title: '¡El registro se ha eliminado correctamente!',
                                    showConfirmButton: false,
                                    timer: 4000
                                })
                                return window.location = '/delete/' + id
                            }
                        }
                    })
                } else if (
                    result.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire(
                        'Cancelado',
                        'Gracias por mantener a salvo la Bitacora 😘',
                        'error'
                    )
                }
            })
        }
    </script>

    <script>
        function confirmEdit(id) {
            Swal.fire({
                icon: 'question',
                title: 'Contraseña',
                html: `<input type="password" id="password" class="swal2-input" placeholder="Ingresa la contraseña para eliminar">`,
                confirmButtonText: 'OK',
                preConfirm: () => {
                    const password = Swal.getPopup().querySelector('#password').value
                    if (password === '') {
                        Swal.showValidationMessage(`Por favor, ingresa una contraseña`)
                    } else if (password === '!edit') {                        
                        return window.location = '/edit/' + id
                    }
                }
            })
        } 
    </script>
