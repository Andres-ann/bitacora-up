<!doctype html>
<html lang="es">

<head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://i.ibb.co/ZNyjQ2g/favicon.jpg">

    <!-- Bootstrap CSS & Datatables -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.11.4/css/dataTables.bootstrap5.min.css">

    <title>Bitacora UP</title>
</head>

<body>
    <div class="container">
        <div class="card mt-5 p-lg-5 mx-auto shadow">

            <!-- Header-->
            <div class="col-11 col-md-8 mx-auto card text-center mt-3 mb-5 pb-5 shadow">
                <div class="mx-auto">
                    <img src="https://i.ibb.co/6mMLN6B/logoup.png" alt="logoUP"
                        class="rounded-circle img-fluid mt-5 shadow">
                </div>
                <div class="card-titlemt-4">
                    <h1 class="display-1">Bitáctora UP</h1>
                </div>

                <div>
                    <h3 class="display-6">Descubrí una frase aleatoria</h3>
                </div>
                <div class="d-flex justify-content-center">
                    <a href="/view" type="button" class="btn btn-lg btn-danger m-3 shadow" data-bs-toggle="modal"
                        data-bs-target="#modal">
                        Hace click aca!
                    </a>
                </div>
            </div>

            <!-- Modal -->
            <div class="modal fade" id="modal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <h5 class="display-6"> </h5>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-outline-secondary">
                                <i class="bi bi-hand-thumbs-up"></i>
                                <span class="badge bg-secondary"> 0 </span>
                            </button>
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Salir</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card-body">
                <div class="d-flex justify-content-end mb-4">
                    <a href="/create" class="btn btn-lg btn-success">
                        <i class="bi bi-plus-circle"></i>
                        Agregar
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="table align-middle" id="frases">
                        <thead>
                            <tr class="text-center">
                                <th scope="col" class="col-1">#</th>
                                <th scope="col" class="col-6">Frase</th>
                                <th scope="col" class="col-1">Autor</th>
                                <th scope="col" class="col-2">Valoración</th>
                                <th scope="col" class="col-2">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% results.forEach((frases)=> { %>
                            <tr>
                                <td scope="row" class="text-center"> <%= frases.id %></td>
                                <td><%= frases.frase %></td>
                                <td><%= frases.autor %></td>
                                <td class="text-center">
                                    <button class="btn btn-outline-warning">
                                        <i class="bi bi-star"></i>
                                        <span class="badge bg-warning"> <%= frases.likes %> </span>
                                    </button>
                                </td>
                                <td class="text-center">
                                    <a onclick="confirmEdit(<%= frases.id %>)" class="btn btn-outline-warning mb-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a onclick="confirm(<%= frases.id %>)" class="btn btn-outline-danger mb-1">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>


    <!-- Datatable -->
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://cdn.datatables.net/1.11.4/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.11.4/js/dataTables.bootstrap5.min.js"></script>
    <script>
        $(document).ready(function () {
            $('#frases').DataTable({
                "order": [[ 0, "desc" ]],
                language: {
                    "url": "//cdn.datatables.net/plug-ins/1.10.16/i18n/Spanish.json"
                }
            });
        });
    </script>

    <!-- Bootstrap Bundle with Popper -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p" crossorigin="anonymous">
    </script>
    <script src="//cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <!-- Alert Delete -->
    <script>
        function confirm(id) {
            const swalWithBootstrapButtons = Swal.mixin({
                customClass: {
                    confirmButton: 'btn btn-success',
                    cancelButton: 'btn btn-danger'
                },
                buttonsStyling: false
            })

            swalWithBootstrapButtons.fire({
                title: '¿Estás seguro que deseas eliminar esta frase?',
                text: "Esta acción no tiene vuelta atrás!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Si, eliminar',
                cancelButtonText: 'Cancelar',
                reverseButtons: true
            }).then((result) => {
                if (result.isConfirmed) {
                    Swal.fire({
                        icon: 'question',
                        title: 'Ingresa la contraseña para eliminar',
                        html: `<input type="password" id="password" class="swal2-input" placeholder="Contraseña...">`,
                        confirmButtonText: 'OK',
                        preConfirm: () => {
                            const password = Swal.getPopup().querySelector('#password').value
                            if (password === '') {
                                Swal.showValidationMessage(`Por favor, ingresa una contraseña`)
                            } else if (password === '!delete') {
                                Swal.fire({
                                    position: 'center',
                                    icon: 'success',
                                    title: '¡El registro se ha eliminado correctamente!',
                                    showConfirmButton: false,
                                    timer: 4000
                                })
                                return window.location = '/delete/' + id
                            }
                        }
                    })
                } else if (
                    result.dismiss === Swal.DismissReason.cancel
                ) {
                    swalWithBootstrapButtons.fire(
                        'Cancelado',
                        'Gracias por mantener a salvo la Bitacora 😘',
                        'error'
                    )
                }
            })
        }
    </script>

    <script>
        function confirmEdit(id) {
            Swal.fire({
                icon: 'question',
                title: 'Contraseña',
                html: `<input type="password" id="password" class="swal2-input" placeholder="Ingresa la contraseña para eliminar">`,
                confirmButtonText: 'OK',
                preConfirm: () => {
                    const password = Swal.getPopup().querySelector('#password').value
                    if (password === '') {
                        Swal.showValidationMessage(`Por favor, ingresa una contraseña`)
                    } else if (password === '!edit') {                        
                        return window.location = '/edit/' + id
                    }
                }
            })
        } 
    </script>
</body>

</html>