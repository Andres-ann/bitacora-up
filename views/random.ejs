<!DOCTYPE html>
<html lang="es">
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="https://i.ibb.co/ZNyjQ2g/favicon.jpg" />

    <link rel="stylesheet" href="../assets/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@300;400;500;700&display=swap" rel="stylesheet">

    <!-- Bootstrap CSS & Datatables -->
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-1BmE4kWBq78iYhFldvKuhfTAU6auU8tT94WrHftjDbrCEXSU1oBoqyl2QvZ6jIW3"
      crossorigin="anonymous"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css"
    />
    <link
      rel="stylesheet"
      href="https://cdn.datatables.net/1.11.4/css/dataTables.bootstrap5.min.css"
    />

    <title>Bitacora UP</title>
  </head>
  <body>
    <div class="container">
        <div class="row justify-content-md-center p-3 p-sm-5">
          <div class="col-sm-6 card shadow-lg text-center">
            <div class="card-body">
              <a href="/" class="d-flex flex-row-reverse bd-highlight mt-2">
                <i class="bi bi-gear text-muted text-decoration-none"></i>
              </a>        
              <img src="https://i.ibb.co/6mMLN6B/logoup.png" alt="logoUP" class="rounded-circle img-fluid shadow">
              <h1 class="display-3 p-sm-3">Bitácora UP</h1>
              <h3 class="display-6 p-sm-3">Descubrí una frase random!</h3>
    
              <!-- Button trigger modal -->
              <button type="button" class="btn btn-lg btn-danger m-3 mb-sm-5 shadow" data-bs-toggle="modal"
                data-bs-target="#exampleModal">                               
                Hace click aca
                <i class="bi bi-shuffle"></i>
              </button>
    
              <!-- Modal -->
              <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel"
                aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered">
                  <div class="modal-content">
                    <div class="modal-header">    
                      <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                      <div class="row">                    
                        <div class="col-12 pt-4 fst-italic">
                            <% if (random) { %>
                                <div class="text-center display-6">
                                  <div class="card-body">
                                    <h3 class="text-capitalize pb-3"> <%= random.frase %></h3>
                                    <h3 class="text-capitalize text-muted"> Dijo <%= random.autor %> </h3>
                                  </div>
                                </div>
                                <% } %>
                        </div>
                        <div class="modal-footer">
                          <div>
                            <button type="button" class="btn btn-light" data-bs-dismiss="modal" onclick="location.reload()">Cerrar</button>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
    <script
      src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"
      integrity="sha384-ka7Sk0Gln4gmtz2MlQnikT1wXgYsOg+OMhuP+IlRH9sENBO0LRn5q+8nbTov4+1p"
      crossorigin="anonymous"
    ></script>
  </body>
</html>
